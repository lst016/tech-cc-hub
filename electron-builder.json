{
    "appId": "com.devagentforge.techcchub",
    "productName": "tech-cc-hub",
    "files": [
        "dist-electron",
        "dist-react",
        "build/icon.png",
        "node_modules/sqlite-vec/**/*",
        "node_modules/sqlite-vec-*/*",
        "node_modules/@anthropic-ai/claude-agent-sdk/**/*",
        "node_modules/@anthropic-ai/claude-agent-sdk-*/*"
    ],
    "extraResources": [
        "dist-electron/preload.cjs",
        {
            "from": "scripts/knowledge/run-repowiki.py",
            "to": "scripts/knowledge/run-repowiki.py"
        },
        {
            "from": "third_party/repowiki/src",
            "to": "third_party/repowiki/src"
        }
    ],
    "publish": [
        {
            "provider": "github",
            "owner": "lst016",
            "repo": "tech-cc-hub",
            "releaseType": "release",
            "publishAutoUpdate": true
        }
    ],
    "asarUnpack": [
        "node_modules/sqlite-vec/**/*",
        "node_modules/sqlite-vec-*/*",
        "node_modules/@anthropic-ai/claude-agent-sdk/**/*",
        "node_modules/@anthropic-ai/claude-agent-sdk-*/*"
    ],
    "afterPack": "scripts/after-pack-win-icon.cjs",
    "icon": "./build/icon",
    "mac": {
        "identity": null,
        "target": [
            "dmg",
            "zip"
        ]
    },
    "linux": {
        "target": "AppImage",
        "category": "Utility"
    },
    "win": {
        "target": [
            "nsis"
        ]
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true
    }
}

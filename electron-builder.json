{
    "appId": "com.devagentforge.techcchub",
    "productName": "tech-cc-hub",
    "protocols": [
        {
            "name": "tech-cc-hub Codex OAuth callback",
            "schemes": [
                "tech-cc-hub"
            ]
        }
    ],
    "files": [
        "dist-electron",
        "dist-react",
        "build/icon.png",
        "node_modules/better-sqlite3/**/*",
        "node_modules/@anthropic-ai/claude-agent-sdk/**/*",
        "node_modules/@anthropic-ai/claude-agent-sdk-*/*",
        "node_modules/@openai/codex/**/*",
        "node_modules/@openai/codex-*/**/*",
        "node_modules/@colbymchenry/codegraph/**/*",
        "node_modules/@colbymchenry/codegraph-*/**/*"
    ],
    "extraResources": [
        "dist-electron/preload.cjs",
        {
            "from": "plugins/codex-canvas",
            "to": "plugins/codex-canvas",
            "filter": [
                "**/*",
                "!node_modules{,/**/*}"
            ]
        }
    ],
    "publish": [
        {
            "provider": "generic",
            "url": "https://lushengtao.public.pookgitlab.com/tech-cc-hub/releases",
            "channel": "latest"
        }
    ],
    "asarUnpack": [
        "node_modules/better-sqlite3/**/*",
        "node_modules/@anthropic-ai/claude-agent-sdk/**/*",
        "node_modules/@anthropic-ai/claude-agent-sdk-*/*",
        "node_modules/@openai/codex/**/*",
        "node_modules/@openai/codex-*/**/*",
        "node_modules/@colbymchenry/codegraph/**/*",
        "node_modules/@colbymchenry/codegraph-*/**/*"
    ],
    "afterPack": "scripts/after-pack-win-icon.cjs",
    "icon": "./build/icon",
    "mac": {
        "identity": null,
        "target": [
            "dmg",
            "zip"
        ]
    },
    "linux": {
        "target": "AppImage",
        "category": "Utility"
    },
    "win": {
        "icon": "build/icon.ico",
        "target": [
            "nsis"
        ]
    },
    "nsis": {
        "include": "build/installer.nsh",
        "installerIcon": "build/icon.ico",
        "uninstallerIcon": "build/icon.ico",
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true
    }
}

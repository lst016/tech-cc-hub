{
	"name": "tech-cc-hub",
	"private": true,
	"version": "0.1.61",
	"type": "module",
	"main": "dist-electron/electron/main.js",
	"scripts": {
		"rebuild": "npx electron-rebuild -f -w better-sqlite3",
		"dev": "node scripts/dev.mjs",
		"dev:react": "vite",
		"dev:electron": "npm run prepare:workspace-plugins && bun run transpile:electron && node scripts/dev-electron.mjs",
		"qa:smoke": "bash scripts/qa/electron-autostart-smoke.sh \"请只回复：SMOKE_OK\"",
		"qa:slash": "bash scripts/qa/electron-autostart-smoke.sh \"/debug\"",
		"qa:codex": "SMOKE_TIMEOUT_SECONDS=120 bash scripts/qa/electron-autostart-smoke.sh \"/codex consult 你好，只回复 CODEX_SMOKE_OK\"",
		"qa:continue": "bash scripts/qa/electron-autostart-smoke.sh \"请只回复：SMOKE_ROUND_1\" \"请只回复：SMOKE_ROUND_2\"",
		"qa:chat-ui": "node scripts/qa/chat-ui-smoke.cjs",
		"qa:sidebar-plan-preview": "node scripts/qa/sidebar-plan-preview-smoke.cjs",
		"qa:side-conversation": "node scripts/qa/side-conversation-smoke.cjs",
		"qa:collapsed-session-rail": "node scripts/qa/collapsed-session-rail-smoke.cjs",
		"qa:cron-ui": "node scripts/qa/cron-ui-smoke.cjs",
		"qa:conversation-turn-timeline": "node scripts/qa/conversation-turn-timeline-smoke.cjs",
		"qa:chat-selection-comment": "npm run build && node scripts/qa/chat-selection-comment-smoke.cjs",
		"qa:design-element": "npm run transpile:electron && electron scripts/qa/design-element-tool-smoke.mjs",
		"qa:preview": "node scripts/qa/preview-workbench-smoke.cjs",
		"qa:enter": "node scripts/qa/playwright-enter-smoke.cjs",
		"qa:packaged": "node scripts/qa/packaged-smoke.cjs",
		"qa:window:list": "bash scripts/qa/window-id-tools.sh list",
		"qa:window:capture": "bash scripts/qa/window-id-tools.sh capture",
		"codex:oauth:setup": "node scripts/codex-oauth-setup.mjs",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"test:activity-rail-model": "tsc --project test/electron/tsconfig.json && node --test dist-test/test/electron/activity-rail-model.test.js",
		"test:electron:build": "tsc --project test/electron/tsconfig.json",
		"test:electron:cron": "npm run test:electron:build && cross-env CRON_TEST_FILES=\"dist-test/test/electron/cron-*.test.js\" electron --no-sandbox scripts/test-electron.mjs",
		"test:electron:all": "npm run test:electron:build && cross-env CRON_TEST_FILES=\"dist-test/test/electron/*cron*.test.js\" electron --no-sandbox scripts/test-electron.mjs",
		"transpile:electron": "tsc --project src/electron/tsconfig.json",
		"prepare:workspace-plugins": "node scripts/build-canvas-plugin-runtime.mjs",
		"package:mac": "npm run prepare:workspace-plugins && bun run transpile:electron && bun run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip --arm64 --publish never",
		"package:mac:fast": "npm run prepare:workspace-plugins && bun run transpile:electron && bun run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir --arm64 --publish never",
		"package:win": "node scripts/package-win-safe.mjs",
		"dist:mac-arm64": "npm run prepare:workspace-plugins && bun run transpile:electron && bun run build && electron-builder --mac --arm64",
		"dist:mac-x64": "npm run prepare:workspace-plugins && bun run transpile:electron && bun run build && electron-builder --mac --x64",
		"dist:win": "node scripts/package-win-safe.mjs",
		"dist:win:stable": "node scripts/package-win-safe.mjs",
		"dist:linux": "npm run prepare:workspace-plugins && bun run transpile:electron && bun run build && electron-builder --linux --x64",
		"release:mac-arm64": "npm run prepare:workspace-plugins && npm run transpile:electron && npm run build && electron-builder --mac --arm64 --publish always",
		"release:mac-x64": "npm run prepare:workspace-plugins && npm run transpile:electron && npm run build && electron-builder --mac --x64 --publish always",
		"release:win-x64": "npm run dist:win",
		"release:github": "node scripts/github-release.mjs"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.3.187",
		"@arco-design/web-react": "^2.66.14",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/view": "^6.41.1",
		"@colbymchenry/codegraph": "1.2.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@floating-ui/react": "^0.27.19",
		"@gitgraph/react": "^1.6.0",
		"@icon-park/react": "^1.4.2",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@monaco-editor/react": "^4.7.0",
		"@openai/codex": "0.144.3",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@tailwindcss/vite": "^4.1.18",
		"@types/diff": "^7.0.2",
		"@types/lodash-es": "^4.17.12",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@uiw/react-codemirror": "^4.25.9",
		"ahooks": "^3.9.7",
		"better-sqlite3": "^12.9.0",
		"classnames": "^2.5.1",
		"croner": "^10.0.1",
		"diff": "^9.0.0",
		"diff2html": "^3.4.56",
		"echarts": "^6.1.0",
		"electron-log": "^5.4.3",
		"electron-updater": "^6.8.3",
		"eventemitter3": "^5.0.4",
		"highlight.js": "^11.11.1",
		"i18next": "^26.0.8",
		"katex": "^0.16.45",
		"lodash-es": "^4.18.1",
		"lucide-react": "^1.14.0",
		"mermaid": "^11.15.0",
		"mitt": "^3.0.1",
		"monaco-editor": "^0.55.1",
		"os-utils": "^0.0.14",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-i18next": "^17.0.6",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.14.2",
		"react-syntax-highlighter": "^16.1.1",
		"rehype-highlight": "^7.0.2",
		"rehype-katex": "^7.0.1",
		"rehype-raw": "^7.0.0",
		"remark-breaks": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"simple-git": "^3.36.0",
		"sonner": "^2.0.7",
		"streamdown": "^2.5.0",
		"swr": "^2.4.1",
		"tailwindcss": "^4.1.18",
		"vite-tsconfig-paths": "^6.0.3",
		"zod": "^4.4.2",
		"zustand": "^5.0.10"
	},
	"overrides": {
		"tree-sitter-wasms": "0.1.11"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.59.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/os-utils": "^0.0.4",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"ag-psd": "^31.0.0",
		"cross-env": "^10.1.0",
		"cross-spawn": "^7.0.6",
		"electron": "^39.2.7",
		"electron-builder": "^26.4.0",
		"esbuild": "^0.27.2",
		"eslint": "^9.39.2",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.26",
		"globals": "^17.0.0",
		"pngjs": "^7.0.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.52.0",
		"vite": "^7.3.1"
	}
}

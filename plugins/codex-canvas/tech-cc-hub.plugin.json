{
  "id": "codex-canvas",
  "label": "Canvas",
  "surface": "browser-view",
  "start": {
    "command": "node",
    "args": [
      "bin/codex-canvas.mjs",
      "start",
      "--host",
      "127.0.0.1",
      "--port",
      "{port}",
      "--project",
      "{workspace}",
      "--thread-id",
      "{sessionId}"
    ],
    "urlTemplate": "http://127.0.0.1:{port}/?threadId={sessionId}"
  },
  "permissions": [
    "session.snapshot",
    "session.send"
  ]
}

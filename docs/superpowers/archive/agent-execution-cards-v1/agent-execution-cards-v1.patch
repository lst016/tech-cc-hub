+const fs = require('fs');
+const { chromium } = require('@playwright/test');
+
+const DEFAULT_URL = process.env.AGENT_CARDS_QA_URL || 'http://localhost:4173/';
+const CHROME_PATH = '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome';
+
+function isKnownDevConsoleNoise(line) {
+  return (
+    line.includes('violates the following Content Security Policy directive')
+    || line.includes('Refused to connect because it violates the document')
+    || line.includes('Download the React DevTools')
+    || line.includes('浏览器预览态不支持 IPC invoke')
+    || line.includes('Failed to invoke session list')
+  );
+}
+
+async function main() {
+  const browser = await chromium.launch({
+    headless: true,
+    executablePath: fs.existsSync(CHROME_PATH) ? CHROME_PATH : undefined,
+  });
+  const page = await browser.newPage({ viewport: { width: 1500, height: 950 } });
+  const logs = [];
+  page.on('console', (message) => logs.push(`[console:${message.type()}] ${message.text()}`));
+  page.on('pageerror', (error) => logs.push(`[pageerror] ${error.stack || error.message}`));
+
+  await page.goto(DEFAULT_URL, { waitUntil: 'domcontentloaded', timeout: 20000 });
+  await page.waitForTimeout(1500);
+
+  await page.evaluate(() => {
+    window.dispatchEvent(new CustomEvent('techcc:open-agent-run', {
+      detail: { toolUseId: 'qa-low-detail-agent', agentName: 'QA Low Detail Agent' },
+    }));
+  });
+  await page.waitForTimeout(700);
+
+  const visibleTabText = await page.locator('body').innerText({ timeout: 8000 });
+  if (visibleTabText.includes('QA Low Detail Agent')) {
+    throw new Error('Low-detail agent event created a fake agent transcript tab');
+  }
+
+  const fatalLogs = logs.filter((line) => (
+    (line.includes('[pageerror]') || line.includes('[console:error]'))
+    && !isKnownDevConsoleNoise(line)
+  ));
+  if (fatalLogs.length > 0) {
+    throw new Error(`Agent cards QA saw fatal browser logs:\n${fatalLogs.join('\n')}`);
+  }
+
+  await browser.close();
+  console.log('AGENT_EXECUTION_CARDS_QA_OK');
+}
+
+main().catch(async (error) => {
+  console.error(error);
+  process.exit(1);
+});

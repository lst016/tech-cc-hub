diff --git a/src/ui/utils/agent-transcript.ts b/src/ui/utils/agent-transcript.ts
new file mode 100644
index 0000000..1e36f88
--- /dev/null
+++ b/src/ui/utils/agent-transcript.ts
@@ -0,0 +1,111 @@
+import type { StreamMessage } from "../types.js";
+
+export type AgentTranscriptRunTarget = {
+  id: string;
+  taskId?: string;
+  toolUseId?: string;
+  timelineIds: string[];
+};
+
+function contentArrayFromMessage(message: StreamMessage): unknown[] {
+  const record = message as { message?: { content?: unknown } };
+  const content = record.message?.content;
+  if (!content) return [];
+  return Array.isArray(content) ? content : [content];
+}
+
+function messageToolUseIds(message: StreamMessage): string[] {
+  return contentArrayFromMessage(message)
+    .map((content) => {
+      const record = typeof content === "object" && content !== null
+        ? content as { type?: unknown; id?: unknown }
+        : null;
+      return record?.type === "tool_use" && typeof record.id === "string" ? record.id : "";
+    })
+    .filter(Boolean);
+}
+
+function messageToolResultIds(message: StreamMessage): string[] {
+  return contentArrayFromMessage(message)
+    .map((content) => {
+      const record = typeof content === "object" && content !== null
+        ? content as { type?: unknown; tool_use_id?: unknown }
+        : null;
+      return record?.type === "tool_result" && typeof record.tool_use_id === "string" ? record.tool_use_id : "";
+    })
+    .filter(Boolean);
+}
+
+function messageParentToolUseId(message: StreamMessage): string {
+  if (message.type !== "assistant") return "";
+  const parent = (message as { parent_tool_use_id?: unknown }).parent_tool_use_id;
+  return typeof parent === "string" ? parent : "";
+}
+
+function stringifyContent(value: unknown): string {
+  if (typeof value === "string") return value;
+  if (value === null || value === undefined) return "";
+  try {
+    return JSON.stringify(value);
+  } catch {
+    return String(value);
+  }
+}
+
+function isLowInformationAgentText(text: string): boolean {
+  const normalized = text.replace(/\s+/g, " ").trim();
+  if (!normalized) return true;
+  if (/^Task\s*#?\w+\s+created successfully\b/i.test(normalized)) return true;
+  if (/No messages from Codex/i.test(normalized)) return true;
+  if (/agents?\s+(?:are|is)\s+still\s+(?:working|running)/i.test(normalized)) return true;
+  if (/task list shows/i.test(normalized)) return true;
+  return false;
+}
+
+function messageHasDetailedAgentContent(message: StreamMessage): boolean {
+  return contentArrayFromMessage(message).some((content) => {
+    const record = typeof content === "object" && content !== null
+      ? content as { type?: unknown; name?: unknown; text?: unknown; content?: unknown }
+      : null;
+
+    if (record?.type === "text" && typeof record.text === "string") {
+      return !isLowInformationAgentText(record.text);
+    }
+    if (record?.type === "tool_result") {
+      return !isLowInformationAgentText(stringifyContent(record.content));
+    }
+    if (record?.type === "tool_use" && typeof record.name === "string") {
+      return !["Task", "Agent", "TaskCreate", "TaskGet", "TaskList", "TaskUpdate", "TeamCreate", "TeamDelete", "SendMessage"].includes(record.name);
+    }
+    return false;
+  });
+}
+
+export function hasDetailedAgentTranscript(messages: StreamMessage[]): boolean {
+  return messages.some(messageHasDetailedAgentContent);
+}
+
+export function buildAgentTranscriptMessages(
+  messages: StreamMessage[],
+  run: AgentTranscriptRunTarget | null,
+): StreamMessage[] {
+  if (!run) return [];
+  const linkedIds = new Set([
+    run.id,
+    run.taskId,
+    run.toolUseId,
+    ...run.timelineIds,
+  ].filter((value): value is string => Boolean(value)));
+
+  return messages.filter((message) => {
+    if (message.type === "assistant") {
+      const parentToolUseId = messageParentToolUseId(message);
+      if (parentToolUseId && linkedIds.has(parentToolUseId)) return true;
+      return messageToolUseIds(message).some((toolUseId) => linkedIds.has(toolUseId));
+    }
+    if (message.type === "user") {
+      return messageToolResultIds(message).some((toolUseId) => linkedIds.has(toolUseId));
+    }
+    return false;
+  });
+}

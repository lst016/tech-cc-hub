+function getToolInputRecord(item: ActivityTimelineItem): Record<string, unknown> {
+  const section = item.detailSections.find((detailSection) => detailSection.id === "tool-input");
+  if (!section?.raw) return {};
+  return asRecord(tryParseJson(section.raw)) ?? {};
+}
+
+function getToolInputText(item: ActivityTimelineItem, ...keys: string[]): string {
+  const input = getToolInputRecord(item);
+  for (const key of keys) {
+    const value = input[key];
+    if (typeof value === "string" && value.trim()) return value.trim();
+    if (typeof value === "number" && Number.isFinite(value)) return String(value);
+  }
+  return "";
+}
+
+function getToolOutputRaw(item: ActivityTimelineItem): string {
+  return item.detailSections.find((detailSection) => detailSection.id === "tool-output")?.raw?.trim() ?? "";
+}
+
+function collectReadableText(value: unknown, depth = 0): string[] {
+  if (depth > 4 || value === null || value === undefined) return [];
+  if (typeof value === "string") return value.trim() ? [value.trim()] : [];
+  if (typeof value === "number" || typeof value === "boolean") return [String(value)];
+  if (Array.isArray(value)) return value.flatMap((item) => collectReadableText(item, depth + 1));
+  if (!isRecord(value)) return [];
+
+  const preferredKeys = [
+    "result",
+    "content",
+    "output",
+    "text",
+    "message",
+    "summary",
+    "report",
+    "response",
+    "final",
+    "description",
+    "body",
+    "markdown",
+  ];
+  const preferred = preferredKeys.flatMap((key) => collectReadableText(value[key], depth + 1));
+  if (preferred.length > 0) return preferred;
+
+  return Object.values(value).flatMap((item) => collectReadableText(item, depth + 1));
+}
+
+function extractReadableToolOutput(raw: string): string {
+  const trimmed = raw.trim();
+  if (!trimmed) return "";
+  const parsed = tryParseJson(trimmed);
+  if (parsed === null) return trimmed;
+  const texts = collectReadableText(parsed)
+    .map((text) => text.trim())
+    .filter(Boolean);
+  return texts.length > 0 ? Array.from(new Set(texts)).join("\n\n") : trimmed;
+}
+
+function extractTeamTaskIdFromText(text: string): string {
+  const match =
+    text.match(/\bTask\s*#\s*([A-Za-z0-9_-]+)/i) ||
+    text.match(/\btask[_\s-]?id["'\s:=#]+([A-Za-z0-9_-]+)/i) ||
+    text.match(/\bid["'\s:=#]+([A-Za-z0-9_-]+)/i);
+  return match?.[1]?.trim() ?? "";
+}
+
+function getAgentTeamTaskGroupKey(item: ActivityTimelineItem): string | null {
+  if (item.toolName !== "TaskCreate" && item.toolName !== "TaskGet" && item.toolName !== "TaskUpdate") {
+    return null;
+  }
+
+  const taskId =
+    getToolInputText(item, "taskId", "task_id", "id") ||
+    extractTeamTaskIdFromText(getToolOutputRaw(item)) ||
+    extractTeamTaskIdFromText(item.detail);
+  if (taskId) return `team-task:${taskId}`;
+
+  const subject = getToolInputText(item, "subject", "description", "title");
+  return subject ? `team-task-subject:${subject}` : null;
+}
+
+function isAgentRunToolName(toolName?: string): boolean {
+  return Boolean(toolName && AGENT_RUN_TOOL_NAMES.has(toolName));
+}
+
+function inferAgentRunKind(item: ActivityTimelineItem): ActivityAgentRunKind {
+  if (item.toolName && AGENT_TEAM_TOOL_NAMES.has(item.toolName)) return "agent_team";
+  if (item.toolName === "Agent") return getToolInputText(item, "team_name") ? "team_member" : "sub_agent";
+  if (item.nodeSubtype === "local_workflow" || item.chips.includes("本地工作流")) return "local_workflow";
+  if (item.nodeKind === "agent_progress" || item.nodeKind === "handoff" || item.provenance === "sub_agent") return "sub_agent";
+  return "background";
+}
+
+function titleFromAgentTool(item: ActivityTimelineItem): string {
+  const toolName = item.toolName ?? "";
+  const input = getToolInputRecord(item);
+  const name = typeof input.name === "string" ? input.name.trim() : "";
+  const teamName = typeof input.team_name === "string" ? input.team_name.trim() : "";
+  const subject = typeof input.subject === "string" ? input.subject.trim() : "";
+  const to = typeof input.to === "string" ? input.to.trim() : "";
+  const description = getToolInputText(item, "description", "prompt");
+
+  if (toolName === "Task") return `子 Agent：${description || item.title}`;
+  if (toolName === "Agent") return `${teamName ? `${teamName} · ` : ""}${name || "Agent"}：${description || item.title}`;
+  if (toolName === "TeamCreate") return `Agent Team：${teamName || name || description || "新团队"}`;
+  if (toolName === "SendMessage") return `发送给 ${to || name || teamName || "Agent"}`;
+  if (toolName === "TaskCreate") return `团队任务：${subject || description || item.title}`;
+  if (toolName === "TaskUpdate") return `更新团队任务：${subject || getToolInputText(item, "taskId") || item.title}`;
+  if (toolName === "TaskGet") return `读取团队任务：${getToolInputText(item, "taskId") || item.title}`;
+  if (toolName === "TaskList") return "查看团队任务列表";
+  if (toolName === "TeamDelete") return `结束 Agent Team：${teamName || name || item.title}`;
+  return item.title;
+}
+
+function isAgentRunSeed(item: ActivityTimelineItem): boolean {
+  return (
+    item.nodeKind === "agent_progress" ||
+    item.nodeKind === "handoff" ||
+    item.provenance === "sub_agent" ||
+    isAgentRunToolName(item.toolName)
+  );
+}
+
+function getAgentRunGroupKey(item: ActivityTimelineItem): string | null {
+  const teamTaskKey = getAgentTeamTaskGroupKey(item);
+  if (teamTaskKey) return teamTaskKey;
+  if (item.parentTaskId) return item.parentTaskId;
+  if (isAgentRunToolName(item.toolName)) return item.id;
+  if (item.nodeKind === "agent_progress" || item.nodeKind === "handoff" || item.provenance === "sub_agent") return item.id;
+  return null;
+}
+
+function statusFromAgentTimeline(items: ActivityTimelineItem[]): {
+  status: ActivityAgentRunStatus;
+  statusLabel: string;
+  tone: ActivityRailTone;
+} {
+  const text = items.map((item) => `${item.statusLabel ?? ""} ${item.detail}`).join("\n");
+  if (items.some((item) => item.tone === "error") || /失败|错误|failed|killed|终止/i.test(text)) {
+    const stopped = /终止|killed|stopped/i.test(text);
+    return { status: stopped ? "stopped" : "failed", statusLabel: stopped ? "已终止" : "失败", tone: "error" };
+  }
+  if (items.some((item) => item.tone === "success" || /完成|成功|已结束/i.test(item.statusLabel ?? ""))) {
+    return { status: "completed", statusLabel: "已完成", tone: "success" };
+  }
+  if (items.some((item) => item.metrics.status === "running" || /运行中|进行中|处理中/i.test(item.statusLabel ?? ""))) {
+    return { status: "running", statusLabel: "运行中", tone: "info" };
+  }
+  return { status: "pending", statusLabel: "已派遣", tone: "warning" };
+}
+
+function buildAgentRunDetailSections(
+  seed: ActivityTimelineItem,
+  items: ActivityTimelineItem[],
+  status: { statusLabel: string },
+  outputText: string,
+): ActivityDetailSection[] {
+  const rows: ActivityDetailRow[] = [
+    { label: "status", value: status.statusLabel },
+    { label: "kind", value: inferAgentRunKind(seed) },
+    { label: "round", value: `第 ${seed.round} 轮` },
+  ];
+  if (seed.parentTaskId) rows.push({ label: "task_id", value: seed.parentTaskId });
+  const teamTaskId = extractTeamTaskIdFromText(seed.id) || extractTeamTaskIdFromText(getToolOutputRaw(seed)) || getToolInputText(seed, "taskId", "task_id", "id");
+  if (teamTaskId) rows.push({ label: "team_task_id", value: teamTaskId });
+  if (seed.toolName) rows.push({ label: "source_tool", value: seed.toolName });
+
+  const sections: ActivityDetailSection[] = [{
+    id: "agent-summary",
+    title: "Agent 摘要",
+    summary: seed.agentDescription || seed.detail || seed.preview,
+    rows,
+  }];
+
+  if (outputText.trim()) {
+    sections.push({
+      id: "agent-output",
+      title: "执行内容",
+      summary: truncate(outputText, 160),
+      rows: [],
+      raw: outputText,
+      rawLabel: "展开完整执行内容",
+    });
+  }
+
+  sections.push({
+    id: "agent-timeline",
+    title: "关联节点",
+    summary: `${items.length} 个执行节点`,
+    rows: items.slice(0, 8).map((item) => ({
+      label: item.statusLabel || item.layer,
+      value: item.title,
+    })),
+  });
+
+  return sections;
+}
+
+function isLowInformationAgentToolOutput(item: ActivityTimelineItem, output: string): boolean {
+  if (!output.trim()) return true;
+  if (item.toolName === "TaskCreate" && /^Task\s*#?\w+\s+created successfully\b/i.test(output.trim())) return true;
+  if (item.toolName === "TeamCreate" && /^Team\b.+created successfully\b/i.test(output.trim())) return true;
+  if (/No messages from Codex/i.test(output)) return true;
+  if (/agents?\s+(?:are|is)\s+still\s+(?:working|running)/i.test(output)) return true;
+  if (/task list shows/i.test(output)) return true;
+  return false;
+}
+
+function getAgentRunOutputText(item: ActivityTimelineItem): string {
+  if (item.nodeKind === "assistant_output" || item.filterKey === "result" || item.nodeKind === "agent_progress") {
+    return item.detail.trim();
+  }
+  if (isAgentRunToolName(item.toolName)) {
+    const toolOutput = extractReadableToolOutput(getToolOutputRaw(item));
+    if (isLowInformationAgentToolOutput(item, toolOutput)) return "";
+    return toolOutput;
+  }
+  return "";
+}
+
+function buildAgentRuns(timelineChronological: ActivityTimelineItem[]): ActivityAgentRun[] {
+  const groupKeys = new Set<string>();
+  for (const item of timelineChronological) {
+    if (!isAgentRunSeed(item) && !item.parentTaskId) continue;
+    const key = getAgentRunGroupKey(item);
+    if (key) groupKeys.add(key);
+  }
+
+  const runs: ActivityAgentRun[] = [];
+  for (const groupKey of groupKeys) {
+    const items = timelineChronological.filter((item) => {
+      if (item.parentTaskId === groupKey) return true;
+      if (getAgentRunGroupKey(item) === groupKey) return true;
+      return item.id === groupKey && isAgentRunSeed(item);
+    });
+    if (items.length === 0) continue;
+
+    const seed = items.find(isAgentRunSeed) ?? items[0]!;
+    const status = statusFromAgentTimeline(items);
+    const title = seed.nodeKind === "agent_progress"
+      ? seed.title.replace(/^启动/, "")
+      : titleFromAgentTool(seed);
+    const outputText = items
+      .map(getAgentRunOutputText)
+      .filter(Boolean)
+      .join("\n\n");
+    const hasExecutionEvidence =
+      outputText.trim().length > 0 ||
+      items.some((item) => item.id !== seed.id && item.parentTaskId === groupKey);
+    if (!hasExecutionEvidence) continue;
+
+    const latestSummary =
+      [...items].reverse().find((item) => item.agentDescription || item.detail)?.agentDescription ||
+      [...items].reverse().find((item) => item.detail)?.detail ||
+      seed.preview ||
+      title;
+
+    runs.push({
+      id: groupKey,
+      taskId: seed.parentTaskId,
+      toolUseId: isAgentRunToolName(seed.toolName) ? seed.id : undefined,
+      title: truncate(title, 120),
+      description: seed.agentDescription || seed.detail || seed.preview,
+      kind: inferAgentRunKind(seed),
+      status: status.status,
+      statusLabel: status.statusLabel,
+      tone: status.tone,
+      round: seed.round,
+      sequence: seed.sequence,
+      chips: Array.from(new Set([
+        seed.toolName,
+        ...seed.chips,
+        ...items.flatMap((item) => item.chips),
+      ].filter((value): value is string => Boolean(value)))).slice(0, 5),
+      timelineIds: items.map((item) => item.id),
+      latestSummary: truncate(latestSummary, 260),
+      outputText,
+      sourceToolName: seed.toolName,
+      metrics: mergeMetrics(...items.map((item) => item.metrics)),
+      detailSections: buildAgentRunDetailSections(seed, items, status, outputText),
+    });
+  }
+
+  return runs.sort((left, right) => right.sequence - left.sequence);
+}
